# Copie este arquivo para terraform.tfvars e preencha com seus valores
# NUNCA commite o terraform.tfvars no git

cluster_name              = "apache"
kubeconfig_path           = "~/.kube/config"
project_id                = "SEU-PROJECT-UUID-AQUI"
client_id                 = "SEU-CLIENT-ID-AQUI"
client_secret             = "SEU-CLIENT-SECRET-AQUI"
ca_cert_path              = "../certs/cert.pem"

# PKI Subscriber cadastrado no painel do Infisical (com auto-renewal habilitado).
# O CronJob abaixo busca o bundle ativo deste subscriber e atualiza o Secret
# corebank-client-tls-secret. O Reloader detecta a mudanca e faz rollout do pod.
subscriber_name           = "corebank-mtls"
subscriber_sync_schedule  = "*/15 * * * *"
